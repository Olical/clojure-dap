{
  "name": "clojure-dap",
  "displayName": "Clojure DAP",
  "description": "Debug Adapter Protocol support for Clojure via CIDER nREPL",
  "version": "0.0.2",
  "publisher": "olical",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/Olical/clojure-dap"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:clojure-dap"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Clojure DAP",
      "properties": {
        "clojure-dap.command": {
          "type": "string",
          "default": "clojure",
          "description": "Executable launched as the DAP server. Defaults to `clojure` on PATH. Set to an absolute path if your `clojure` binary isn't on the GUI PATH (mise/asdf users) or to a wrapper that activates project tooling."
        },
        "clojure-dap.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "-Sdeps",
            "{:deps {uk.me.oli/clojure-dap {:mvn/version \"RELEASE\"}}}",
            "-X",
            "clojure-dap.main/run"
          ],
          "description": "Arguments passed to the launch command. The default pulls clojure-dap from Clojars at the latest release; override the :mvn/version to pin (e.g. \"0.1.311\")."
        }
      }
    },
    "debuggers": [
      {
        "type": "clojure-dap",
        "label": "Clojure DAP",
        "languages": [
          "clojure"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "clojure_dap": {
                "type": "object",
                "description": "Connection options",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "nrepl"
                    ],
                    "default": "nrepl"
                  },
                  "nrepl": {
                    "type": "object",
                    "properties": {
                      "host": {
                        "type": "string",
                        "default": "127.0.0.1"
                      },
                      "port": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "clojure-dap",
            "request": "attach",
            "name": "Attach to nREPL"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Clojure DAP: Attach to nREPL",
            "description": "Attach to a running nREPL server with CIDER middleware",
            "body": {
              "type": "clojure-dap",
              "request": "attach",
              "name": "Attach to nREPL"
            }
          }
        ]
      }
    ]
  }
}
